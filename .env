# Local dev only — leave unset (or delete this file) to fall back to the
# deployed backend in app.json's expo.extra.apiBase.
#
# Uncomment ONE line depending on what you're testing against your local
# dotnet backend (dotnet run --urls "http://0.0.0.0:5000"):
#
# Web (browser on same laptop as backend):
EXPO_PUBLIC_API_URL=http://localhost:5000
#
# Android emulator (same laptop as backend):
# EXPO_PUBLIC_API_URL=http://10.0.2.2:5000
#
# iOS simulator (same laptop as backend):
# EXPO_PUBLIC_API_URL=http://localhost:5000
#
# Physical device (phone on same WiFi as laptop) — replace with your LAN IP:
# EXPO_PUBLIC_API_URL=http://192.168.1.42:5000
